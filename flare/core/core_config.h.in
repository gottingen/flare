#ifndef FLARE_CORE_CONFIG_H_
#define FLARE_CORE_CONFIG_H_

// FLARE_VERSION % 100 is the patch level
// FLARE_VERSION / 100 % 100 is the minor version
// FLARE_VERSION / 10000 is the major version
#define FLARE_VERSION @FLARE_VERSION@
#define FLARE_VERSION_MAJOR @FLARE_VERSION_MAJOR@
#define FLARE_VERSION_MINOR @FLARE_VERSION_MINOR@
#define FLARE_VERSION_PATCH @FLARE_VERSION_PATCH@

/* Execution Spaces */
#cmakedefine FLARE_ENABLE_SERIAL
#cmakedefine FLARE_ENABLE_OPENMP
#cmakedefine FLARE_ENABLE_THREADS
#cmakedefine FLARE_ENABLE_CUDA
#cmakedefine FLARE_ENABLE_MEMKIND
#cmakedefine FLARE_ENABLE_LIBRT

/* General Settings */
#cmakedefine FLARE_ENABLE_CXX17
#cmakedefine FLARE_ENABLE_CXX20
#cmakedefine FLARE_ENABLE_CXX23

#cmakedefine FLARE_ENABLE_IMPL_CUDA_MALLOC_ASYNC
#cmakedefine FLARE_ENABLE_DEBUG
#cmakedefine FLARE_ENABLE_DEBUG_DUALVIEW_MODIFY_CHECK
#cmakedefine FLARE_ENABLE_DEBUG_BOUNDS_CHECK
#cmakedefine FLARE_ENABLE_TUNING
#cmakedefine FLARE_ENABLE_DEPRECATION_WARNINGS
#cmakedefine FLARE_ENABLE_LARGE_MEM_TESTS
#cmakedefine FLARE_ENABLE_COMPLEX_ALIGN
#cmakedefine FLARE_ENABLE_AGGRESSIVE_VECTORIZATION

/* TPL Settings */
#cmakedefine FLARE_ENABLE_HWLOC
#cmakedefine FLARE_USE_LIBRT
#cmakedefine FLARE_ENABLE_HBWSPACE
#cmakedefine FLARE_ENABLE_LIBDL
#cmakedefine FLARE_ENABLE_LIBQUADMATH
#cmakedefine FLARE_IMPL_CUDA_CLANG_WORKAROUND

#cmakedefine FLARE_ARCH_SSE42
#cmakedefine FLARE_ARCH_ARMV80
#cmakedefine FLARE_ARCH_ARMV8_THUNDERX
#cmakedefine FLARE_ARCH_ARMV81
#cmakedefine FLARE_ARCH_ARMV8_THUNDERX2
#cmakedefine FLARE_ARCH_A64FX
#cmakedefine FLARE_ARCH_AVX
#cmakedefine FLARE_ARCH_AVX2
#cmakedefine FLARE_ARCH_AVX512XEON
#cmakedefine FLARE_ARCH_KNC
#cmakedefine FLARE_ARCH_AVX512MIC
#cmakedefine FLARE_ARCH_POWER7
#cmakedefine FLARE_ARCH_POWER8
#cmakedefine FLARE_ARCH_POWER9
#cmakedefine FLARE_ARCH_KEPLER
#cmakedefine FLARE_ARCH_KEPLER30
#cmakedefine FLARE_ARCH_KEPLER32
#cmakedefine FLARE_ARCH_KEPLER35
#cmakedefine FLARE_ARCH_KEPLER37
#cmakedefine FLARE_ARCH_MAXWELL
#cmakedefine FLARE_ARCH_MAXWELL50
#cmakedefine FLARE_ARCH_MAXWELL52
#cmakedefine FLARE_ARCH_MAXWELL53
#cmakedefine FLARE_ARCH_PASCAL
#cmakedefine FLARE_ARCH_PASCAL60
#cmakedefine FLARE_ARCH_PASCAL61
#cmakedefine FLARE_ARCH_VOLTA
#cmakedefine FLARE_ARCH_VOLTA70
#cmakedefine FLARE_ARCH_VOLTA72
#cmakedefine FLARE_ARCH_TURING75
#cmakedefine FLARE_ARCH_AMPERE
#cmakedefine FLARE_ARCH_AMPERE80
#cmakedefine FLARE_ARCH_AMPERE86
#cmakedefine FLARE_ARCH_ADA89
#cmakedefine FLARE_ARCH_HOPPER
#cmakedefine FLARE_ARCH_HOPPER90
#cmakedefine FLARE_ARCH_AMD_ZEN
#cmakedefine FLARE_ARCH_AMD_ZEN2
#cmakedefine FLARE_ARCH_AMD_ZEN3
#cmakedefine FLARE_ARCH_AMD_GFX906
#cmakedefine FLARE_ARCH_AMD_GFX908
#cmakedefine FLARE_ARCH_AMD_GFX90A
#cmakedefine FLARE_ARCH_AMD_GFX942
#cmakedefine FLARE_ARCH_AMD_GFX1030
#cmakedefine FLARE_ARCH_AMD_GFX1100
#cmakedefine FLARE_ARCH_AMD_GPU

#cmakedefine FLARE_IMPL_32BIT
#cmakedefine FLARE_INST_ORDINAL_INT
#cmakedefine FLARE_INST_ORDINAL_INT64_T
#cmakedefine FLARE_INST_OFFSET_INT
#cmakedefine FLARE_INST_OFFSET_SIZE_T
#cmakedefine FLARE_INST_LAYOUT_LEFT
#cmakedefine FLARE_INST_LAYOUT_RIGHT
#cmakedefine FLARE_INST_DOUBLE
#cmakedefine FLARE_INST_FLOAT
#cmakedefine FLARE_INST_HALF
#cmakedefine FLARE_INST_BHALF

#endif  // FLARE_CORE_CONFIG_H_